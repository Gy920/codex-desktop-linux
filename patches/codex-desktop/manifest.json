      "count": 1,
      "already_contains": "--font-mono-default:\"Codex Mono\",ui-monospace"
    },
    {
      "name": "linux-picker-allow-file-selection",
      "glob": ".vite/build/main-*.js",
      "find": "const e=[\"openDirectory\",\"createDirectory\"];await this.shouldShowHiddenFilesInPicker()&&e.push(\"showHiddenFiles\");const i=await x.dialog.showOpenDialog({properties:e,title:\"Select Project Root\"}),n=i.filePaths?.[0];",
      "replace": "const e=process.platform===\"linux\"?[\"openFile\",\"openDirectory\",\"createDirectory\"]:[\"openDirectory\",\"createDirectory\"];await this.shouldShowHiddenFilesInPicker()&&e.push(\"showHiddenFiles\");const i=await x.dialog.showOpenDialog({properties:e,title:\"Select Project Root\"}),n=i.filePaths?.[0];",
      "count": 1,
      "already_contains": "process.platform===\"linux\"?[\"openFile\",\"openDirectory\",\"createDirectory\"]:[\"openDirectory\",\"createDirectory\"]"
    },
    {
      "name": "linux-picker-resolve-parent-directory",
      "glob": ".vite/build/main-*.js",
      "find": "async resolveWorkspaceRoot(e){try{const t=Qe(e,this.host);return(await Se.stat(t)).isDirectory()?y.resolve(t):null}catch(t){return B().warning(\"Failed to stat workspace root\",{safe:{},sensitive:{error:t}}),null}}",
      "replace": "async resolveWorkspaceRoot(e){try{const t=Qe(e,this.host),i=await Se.stat(t);if(i.isDirectory())return y.resolve(t);if(i.isFile()){const n=y.dirname(t),o=await Se.stat(n);if(o.isDirectory())return y.resolve(n)}return null}catch(t){return B().warning(\"Failed to stat workspace root\",{safe:{},sensitive:{error:t}}),null}}",
      "count": 1,
      "already_contains": "if(i.isFile()){const n=y.dirname(t),o=await Se.stat(n);if(o.isDirectory())return y.resolve(n)}"
    },
    {
      "name": "open-file-linux-fallback-file-manager",
      "glob": ".vite/build/main-*.js",
      "find": "if(f=Dk({target:f,hasExplicitTarget:h,platform:process.platform}),!f)throw new Error(\"No available open target\");",
      "replace": "if(f=Dk({target:f,hasExplicitTarget:h,platform:process.platform}),!f){if(process.platform===\"linux\")f=\"fileManager\";else throw new Error(\"No available open target\")}",
      "count": 1,
      "already_contains": "if(f=Dk({target:f,hasExplicitTarget:h,platform:process.platform}),!f){if(process.platform===\"linux\")f=\"fileManager\";else throw new Error(\"No available open target\")}"
